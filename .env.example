# ============================================================
# NLP Pipeline — Environment Configuration
# Copy to .env and fill in your keys
# ============================================================

# --- News Data Sources ---
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
FINNHUB_API_KEY=your_finnhub_key_here
# yfinance does not require a key

# --- PostgreSQL (structured storage) ---
DATABASE_URL=postgresql://nlp_user:nlp_password@localhost:5432/nlp_pipeline

# --- Redis (queue layer) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_STREAM_NAME=news_articles
REDIS_CONSUMER_GROUP=nlp_workers

# --- NLP Models ---
NER_MODEL=dslim/bert-base-NER
SENTIMENT_MODEL=ProsusAI/finbert
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Set to "cuda" if GPU available, else "cpu"
TORCH_DEVICE=cpu

# --- File Storage Paths (raw JSON + FAISS) ---
STORAGE_BASE_DIR=./data
RAW_STORE_DIR=./data/raw
NLP_STORE_DIR=./data/nlp_processed
EVENTS_STORE_DIR=./data/events
VECTOR_STORE_DIR=./data/vectors

# --- Pipeline Settings ---
DEDUP_SIMILARITY_THRESHOLD=0.92
SENTIMENT_WINDOW_SIZE=2
MIN_CLUSTER_SIZE=3
BATCH_SIZE=32
MAX_ARTICLES_PER_SOURCE=50
