# ─────────────────────────────────────────────────────────────────────────────
# Truth Social Archiver — example environment file.
# Copy to `.env` and fill in. NEVER commit a real `.env` (see .gitignore).
# Precedence (high→low): env vars > .env > profile YAML > field defaults.
# See DESIGN.md §11 for the full configuration model.
# ─────────────────────────────────────────────────────────────────────────────

# Which profile to load from src/archiver/config/profiles/<env>.yaml
ARCHIVER_ENV=dev                     # dev | test | prod

# Target account (identity is resolved to a stable ID at runtime).
TARGET_HANDLE=realDonaldTrump

# ── API client (provider-agnostic Mastodon-compatible) ───────────────────────
# Point at any Mastodon-compatible instance you are AUTHORIZED to access.
# NOT defaulted to truthsocial.com: Phase 0 confirmed it blocks anonymous
# automated access at Cloudflare (see docs/adr/0004). Pointing the client there
# anonymously simply raises BlockedError and halts — by design, no evasion.
API_BASE_URL=https://mastodon.social
USER_AGENT=ts-archiver/0.1 (+personal-research; contact-configured)
HTTP_TIMEOUT_S=30
HTTP_MAX_RETRIES=5
BACKOFF_BASE_S=1.0
BACKOFF_CAP_S=60.0

# ── Web UI (`archiver serve`) ─────────────────────────────────────────────────
# Default 8137 (not 8000, which often collides with other dev servers/SSH tunnels).
# If the port is busy, serve auto-skips to the next free one.
WEB_HOST=127.0.0.1
WEB_PORT=8137

# ── Storage ──────────────────────────────────────────────────────────────────
# Minimal profile default is SQLite; scale profile uses Postgres.
DATABASE_URL=sqlite+aiosqlite:///./archive.db
# DATABASE_URL=postgresql+psycopg://archiver:CHANGE_ME@localhost:5432/archive
REDIS_URL=                           # leave blank to use the Redis-free profile

# ── Scheduling / politeness ──────────────────────────────────────────────────
MIN_POLL_INTERVAL_S=60
MAX_POLL_INTERVAL_S=1800
RATE_LIMIT_RPS=0.5                   # conservative by default; do not raise casually

# ── Compliance switches (conservative by default — see DESIGN.md §1.8) ────────
# Each escalation below is an explicit, logged operator decision.
RESPECT_ROBOTS=true                  # honor robots.txt on any HTML surface
ENABLE_HTML_FALLBACK=false           # last-resort Playwright path; off by default
ENABLE_AUTH=false                    # public-only by default; auth has ToS implications
DOWNLOAD_MEDIA=false                 # reference-only unless enabled
ARCHIVE_FOREIGN_REPLIES=false        # replies BY others to the target (volume/3rd-party)

# ── Secrets (optional; never logged, scrubbed from all output) ────────────────
# Only used if ENABLE_AUTH=true. Store securely; do not commit.
AUTH_TOKEN=

# GovInfo (Compilation of Presidential Documents) — Trump's remarks/statements.
# Free key: https://api.data.gov/signup/  (DEMO_KEY works but is rate-limited).
GOVINFO_API_KEY=DEMO_KEY

# ── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                       # TRACE|DEBUG|INFO|WARNING|ERROR|CRITICAL
LOG_JSON=false                       # true in production for structured ingestion
